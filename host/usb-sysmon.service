[Unit]
Description=USB system monitor agent
After=default.target

[Service]
# Adjust ExecStart to wherever this repo lives. If you cloned it to
# ~/usb-sysmon, the %h-relative path below works as-is; otherwise edit it
# to the absolute path of host/sysmon.py.
ExecStart=/usr/bin/python3 %h/usb-sysmon/host/sysmon.py
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
